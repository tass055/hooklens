# HookLens — no paid API keys required
# Copy this file to .env and adjust values as needed

# ── LLM (Ollama) ────────────────────────────────────────────────────────────
# Manual run:   OLLAMA_HOST=http://localhost:11434
# Docker:       OLLAMA_HOST is hardcoded to http://ollama:11434 in docker-compose.yml
#               Do NOT set it here for Docker — the compose file overrides it.
OLLAMA_MODEL=llama3.2:3b
# For better quality (slower, ~5GB): OLLAMA_MODEL=llama3.1:8b

# ── Transcription (Whisper) ─────────────────────────────────────────────────
# tiny ~75MB | base ~150MB | small ~500MB | medium ~1.5GB | large-v3 ~3GB
WHISPER_MODEL=base

# ── CORS (manual run only) ──────────────────────────────────────────────────
# Docker: ALLOWED_ORIGINS is set automatically in docker-compose.yml
# Manual: comma-separated origins, no trailing slash
ALLOWED_ORIGINS=http://localhost:5173

# ── Docker host port ────────────────────────────────────────────────────────
# The port on your machine where the frontend will be available
# Access: http://localhost:{HOST_PORT}
HOST_PORT=80
